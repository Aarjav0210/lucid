{
  "name": "lucid",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "bash scripts/vercel-build.sh",
    "build:local": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:integration": "npx tsx scripts/integration-test.ts",
    "test:integration:gemini": "npx tsx scripts/integration-test.ts --gemini",
    "test:utilities": "tsx scripts/test-utilities.ts",
    "test:adapters": "tsx scripts/test-adapters.ts",
    "test:lifecycle": "dotenv -e .env.local -- tsx scripts/test-lifecycle.ts",
    "pipeline": "dotenv -e .env.local -- tsx src/pipeline/index.ts",
    "pipeline:seed": "dotenv -e .env.local -- tsx scripts/pipeline-seed.ts",
    "pipeline:seed:direct": "dotenv -e .env.local -- env USE_DIRECT_URL_FOR_PIPELINE=1 tsx scripts/pipeline-seed.ts",
    "pipeline:status": "dotenv -e .env.local -- tsx scripts/pipeline-status.ts",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:studio": "dotenv -e .env.local -- prisma studio"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.2.22",
    "@base-ui/react": "^1.3.0",
    "@prisma/client": "^6.19.3",
    "3dmol": "^2.5.4",
    "ai": "^4.3.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "csv-parse": "^5.6.0",
    "date-fns": "^4.1.0",
    "i18n-iso-countries": "^7.14.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.577.0",
    "maplibre-gl": "^5.22.0",
    "next": "^15.3.0",
    "node-cron": "^3.0.3",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.5.0",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0"
  }
}
