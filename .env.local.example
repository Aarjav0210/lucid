# Get your key from https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_key_here

# Vercel Blob token — powers the cross-user screening cache
# (InterPro JSON, ESMFold PDBs, Foldseek JSON) in production.
# On Vercel: automatically injected when a Blob store is linked to the project.
# Locally: only needed if you want dev to share the same cache as prod.
# Without this, caches fall back to the local filesystem under
# .domain-cache/, data/pdb/, and data/foldseek/.
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here