# Get your key from https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_key_here

# ── PandemicPulse Pipeline ──────────────────────────────
# Local Docker: use the same URL for both (pooler not used).
DATABASE_URL="postgresql://pandemic:pandemic@localhost:5432/pandemic_pulse?schema=public"
DIRECT_URL="postgresql://pandemic:pandemic@localhost:5432/pandemic_pulse?schema=public"

# Supabase (production / Vercel): Transaction pooler for the app, direct URL for migrations.
# DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"
# Or use the "Direct connection" string from the dashboard for DIRECT_URL (port 5432).
#
# Long `pipeline:seed` against Supabase: run `npm run pipeline:seed:direct` so the CLI uses DIRECT_URL.
# Optional override: PIPELINE_DATABASE_URL="..." (advanced; see src/lib/prisma.ts).

# Optional API tokens
CDC_SOCRATA_APP_TOKEN=
DELPHI_API_KEY=

# Poll intervals (cron expressions)
POLL_WHO_DON="0 */6 * * *"
POLL_DISEASE_SH="0 * * * *"
POLL_DELPHI="0 4 * * *"
POLL_CDC_SOCRATA="0 5 * * *"
POLL_GLOBAL_HEALTH="0 6 * * *"
STATUS_LIFECYCLE_CRON="0 3 * * *"

LOG_LEVEL="info"
